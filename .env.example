# Database
# Runtime connection for the app. For Neon, use the pooled URL with "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct connection for Prisma CLI migrations/seed. For Neon, use the non-pooler URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# App/Auth
APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-at-least-32-random-characters"
AUTH_TOKEN_PEPPER="replace-with-a-different-32-character-secret"
AUTH_TRUST_PROXY_HEADERS="false"
TRUSTED_DEVICE_DAYS="30"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Bot verification. Local development falls back to Cloudflare's official test keys.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
TURNSTILE_ALLOWED_HOSTNAMES="geraiakun.id,www.geraiakun.id"

# Account email. Use ethereal only outside production; production requires smtp.
EMAIL_TRANSPORT="ethereal"
EMAIL_PREVIEW_ENABLED="true"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="geraiakun <no-reply@geraiakun.id>"

# Midtrans Sandbox
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# Credential vault encryption
CREDENTIAL_ENCRYPTION_KEY="replace-with-at-least-32-random-characters"

# Cron job secret (protects /api/cron/* endpoints)
CRON_SECRET="replace-with-random-string"

# Optional IndexNow URL submission
INDEXNOW_KEY=""

# Optional seed admin
SEED_ADMIN_EMAIL="admin@geraiakun.id"
SEED_ADMIN_PASSWORD="geraiakun-admin"
